# https://github.com/FelixKratz/dotfiles

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

ITEM_DIR="$CONFIG_DIR/items"
PLUGIN_DIR="$CONFIG_DIR/plugins"

FONT="JetBrainsMono Nerd Font"

##### Bar Appearance #####
sketchybar --bar position=top \
                display=all \
                height=30 \
                notch_display_height=34 \
                notch_width=220 \
                margin=8 \
                y_offset=6 \
                blur_radius=12 \
                color="$BAR_COLOR" \
                corner_radius=12 \
                border_color="$BAR_BORDER_COLOR" \
                border_width=1 \
                padding_left=12 \
                padding_right=12 \
                sticky=on \
                topmost=window \
                font_smoothing=on \
                shadow=off

##### Defaults #####
default=(
  padding_left=1
  padding_right=1

  background.color="$ITEM_BG_COLOR"
  background.corner_radius=4
  background.height=18

  icon.font="$FONT:Regular:13.0"
  label.font="$FONT:Regular:11.0"

  icon.color=$WHITE
  label.color=$WHITE

  icon.padding_left=7
  icon.padding_right=4

  label.padding_left=3
  label.padding_right=7
)
sketchybar --default "${default[@]}"
sketchybar --add event aerospace_workspace_change
sketchybar --add event spotify_playback_change com.spotify.client.PlaybackStateChanged

##### Left Items #####
source "$ITEM_DIR/menu.sh"
source "$ITEM_DIR/space.sh"
source "$ITEM_DIR/aerospace_ws.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/display_mode.sh"
source "$ITEM_DIR/workspace_fit.sh"
source "$ITEM_DIR/popup_guard.sh"

##### Right Items #####
source "$ITEM_DIR/spotify.sh"
source "$ITEM_DIR/git.sh"
source "$ITEM_DIR/cpu.sh"
source "$ITEM_DIR/media_block.sh"
source "$ITEM_DIR/clock.sh"

sketchybar --hotload on
sketchybar --update
"$PLUGIN_DIR/display_mode.sh" refresh >/dev/null 2>&1 || true

echo "sketchybar configuration loaded"
